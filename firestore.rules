rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Settings config
    match /configs/main {
      allow read: if true; // Publicly readable for the app's PIN users
      allow write: if request.auth != null; // Only authenticated users can save settings
    }

    // Data sources
    match /sources/{sourceId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /rows/{rowId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // High-speed Chunked Backups
    match /backups/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      match /chunks/{chunkId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
